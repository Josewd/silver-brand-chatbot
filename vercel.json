{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "functions": {
    "app/api/**/*.js": {
      "runtime": "nodejs24.x"
    }
  },
  "env": {
    "VITE_BACKEND_URL": "https://silver-brand-chatbot.onrender.com"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
