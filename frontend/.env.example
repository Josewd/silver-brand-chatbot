# Google Drive API Configuration (Frontend)
# Para obter essas credenciais:
# 1. Acesse https://console.developers.google.com/
# 2. Crie um projeto ou selecione um existente
# 3. Ative a Google Drive API
# 4. Crie credenciais → Chave de API
# 5. Configure restrições (opcional)

# Chave de API do Google (obrigatória)
VITE_GOOGLE_API_KEY=AIzaSyD...

# ID da pasta do Google Drive onde salvar arquivos (opcional)
# Se não especificado, salvará na raiz do Drive
VITE_GOOGLE_DRIVE_FOLDER_ID=1A2B3C4D5E...

# Backend URL (já existente)
VITE_BACKEND_URL=https://silver-brand-chatbot-backend.vercel.app