# Configuração do Frontend (React + Vite)

# === BACKEND URLs ===
# URL do backend WebSocket (Node.js na porta 3002)
# Desenvolvimento: http://localhost:3002
# Produção: https://silver-brand-chatbot.onrender.com
VITE_BACKEND_URL=http://localhost:3002

# === INSTRUÇÕES ===
# Para produção, criar arquivo .env.production com:
# VITE_BACKEND_URL=https://silver-brand-chatbot.onrender.com