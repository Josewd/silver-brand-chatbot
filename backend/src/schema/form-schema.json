{
  "sections": [
    {
      "id": "contact",
      "label": "Contact Details",
      "fields": [
        { "id": "name", "label": "Your name", "type": "text", "required": true },
        { "id": "email", "label": "Your email", "type": "text", "required": true },
        { "id": "company_slogan", "label": "Company name and slogan", "type": "text" },
        { "id": "website", "label": "Website/Instagram", "type": "text" },
        { "id": "phone", "label": "Phone", "type": "text" },
        { "id": "city_state", "label": "City/State", "type": "text" }
      ]
    },
    {
      "id": "basic_info",
      "label": "Basic Information",
      "fields": [
        { "id": "project_type", "label": "New project or redesign?", "type": "select", "options": ["New Project", "Redesign"] },
        { "id": "deadline", "label": "When do you need the project ready?", "type": "select", "options": ["In 1 month", "In 2 months", "Indefinite", "Urgent"] }
      ]
    },
    {
      "id": "deliverables",
      "label": "Delivery List",
      "fields": [
        { "id": "standard_items", "label": "Visual identity items", "type": "multiselect", "options": ["Main Logo", "Reduced Logo", "Color Palette", "Typography", "Brand Manual", "Copyright Registration"] },
        { "id": "extra_items", "label": "Additional items", "type": "multiselect", "options": ["PowerPoint Template", "Instagram Highlights Cover", "Business Card Design", "Print Design"] },
        { "id": "extra_items_info", "label": "Extra information about items", "type": "textarea" }
      ]
    },
    {
      "id": "company_profile",
      "label": "Company Profile",
      "fields": [
        { "id": "about_company", "label": "About the company (what it is, how long it has existed)", "type": "textarea" },
        { "id": "mission_vision_values", "label": "Mission, vision and values", "type": "textarea" },
        { "id": "products_services", "label": "Products/services offered", "type": "textarea" },
        { "id": "current_objectives", "label": "Main objectives today", "type": "textarea" },
        { "id": "differentiator", "label": "Main business differentiator", "type": "textarea" }
      ]
    },
    {
      "id": "positioning",
      "label": "Positioning",
      "fields": [
        { "id": "how_to_be_perceived", "label": "How you want to be perceived", "type": "textarea" },
        { "id": "competitive_differentiator", "label": "What differentiates from competition", "type": "textarea" },
        { "id": "why_choose_you", "label": "Why someone should choose you", "type": "textarea" }
      ]
    },
    {
      "id": "personality",
      "label": "Brand Personality",
      "fields": [
        { "id": "sophisticated_relaxed_scale", "label": "Sophisticated — Relaxed", "type": "scale", "min": 1, "max": 5 },
        { "id": "technical_emotional_scale", "label": "Technical — Emotional", "type": "scale", "min": 1, "max": 5 },
        { "id": "formal_informal_scale", "label": "Formal — Informal", "type": "scale", "min": 1, "max": 5 },
        { "id": "traditional_modern_scale", "label": "Traditional — Modern", "type": "scale", "min": 1, "max": 5 },
        { "id": "exclusive_popular_scale", "label": "Exclusive — Popular", "type": "scale", "min": 1, "max": 5 },
        { "id": "three_words", "label": "3 words that define the brand", "type": "text" }
      ]
    },
    {
      "id": "competitors",
      "label": "Competitors and References",
      "fields": [
        { "id": "local_competitors", "label": "Local/regional/global competitors", "type": "textarea" },
        { "id": "likes_in_brands", "label": "What you like in those brands", "type": "textarea" },
        { "id": "admired_brands", "label": "Brands you admire (even outside your niche)", "type": "textarea" },
        { "id": "extra_competitors_info", "label": "Other information", "type": "textarea" }
      ]
    },
    {
      "id": "visual",
      "label": "Visual Preferences",
      "fields": [
        { "id": "colors_not_want", "label": "Colors you DON'T want", "type": "text" },
        { "id": "colors_want", "label": "Colors you like and want to explore", "type": "text" },
        { "id": "fonts_like", "label": "Types of fonts you like (links)", "type": "text" },
        { "id": "logo_types", "label": "Types of logo you prefer", "type": "multiselect", "options": ["With symbol", "Typography only", "Minimalist", "Classic", "Modern"] },
        { "id": "visual_references", "label": "Visual references (links)", "type": "textarea" }
      ]
    },
    {
      "id": "final",
      "label": "Final",
      "fields": [
        { "id": "anything_to_say", "label": "Anything else to say", "type": "textarea" }
      ]
    }
  ]
}