# Google Drive API Configuration
# Este projeto usa autenticação OAuth 2.0 (conta pessoal do Google), não Service Account.
#
# Passo a passo:
# 1. No Google Cloud Console (projeto "silverbrand"), no client OAuth "Web application" já criado,
#    adicione um Authorized redirect URI, ex: http://localhost:8080/oauth2callback
# 2. Preencha GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET / GOOGLE_OAUTH_REDIRECT_URI abaixo
# 3. Rode `node scripts/google-drive-oauth-setup.js` uma vez e siga as instruções no terminal
# 4. Copie o refresh_token impresso para GOOGLE_OAUTH_REFRESH_TOKEN abaixo

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/oauth2callback
GOOGLE_OAUTH_REFRESH_TOKEN=

# Nome da pasta raiz no Google Drive onde ficam todas as pastas de cliente.
# O backend procura/cria essa pasta automaticamente na raiz do Drive da conta autenticada.
GOOGLE_DRIVE_ROOT_FOLDER_NAME=SilverAssets

# --- Alternativa (não usada por padrão): Service Account ---
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/path/to/service-account-key.json
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"..."}
# GOOGLE_DRIVE_FOLDER_ID=1234567890abcdef

# Configurações existentes...
DATABASE_URL=postgresql://usuario:senha@localhost:5432/silver_brand
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...